    RewriteEngine On

    # Redirect to HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Handle subfolder redirection (remove trailing slash if not a directory)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ $1 [L,R=301]

    # Hide .php extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]

    # Protect sensitive files
    <FilesMatch "\.(sql|env|php\.example)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
    <Files "config.php">
        Order allow,deny
        Deny from all
    </Files>
